---
import HeadBase from '../components/HeadBase.astro';
import PostContent from '../components/PostContent.astro';

import { site } from '../config';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

export type Props = {
  post: CollectionEntry<'blog'>;
};

const { coverImage } = Astro.props.post.data;
---

<html lang={site.lang}>
  <head>
    <HeadBase />
  </head>
  <body>
    <div class="page">
      {
        coverImage && (
          <div class:list={['cover-image', site.coverImageStyle]}>
            <Image src={coverImage} alt="" />
          </div>
        )
      }
      <div class="page-content">
        <aside class="part-left"></aside>
        <div class="part-center">
          <main class="card article-content-card">
            <PostContent post={Astro.props.post} />
          </main>
        </div>
        <aside class="part-right"></aside>
      </div>
    </div>
  </body>
</html>

<style lang="stylus">
  body {
    background-color: var(--background);
    font-family: var(--monospace);
    margin: 0;
    min-height: 100vh;
  }

  .card {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -2px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    transition:
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .page {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;

    parallax() {
      transform-style: preserve-3d;
      perspective: 1px;
    }

    &:has(.parallax) {
      parallax();
    }
    &:has(.half-parallax) {
      parallax();
    }
  }

  .cover-image {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 0 0 auto;

    &.static {
      height: 100vh;
    }

    parallax() {
      transform: translateZ(-1px) scale(2);
    }

    &.parallax {
      height: 100vh;
      parallax();
    }

    &.half-parallax {
      height: 50vh;
      transform-origin: 50% 100%;
      parallax();
    }

    img {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .page-content {
    display: flex;
    flex-direction: row;
    width: 100%;
    padding: 1.5rem;
    box-sizing: border-box;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow: 0 -4px 6px -1px var(--shadow);
    margin-top: -@border-radius;
    z-index: 10;
  }

  .part-left {
    flex: 0 0 20%;
    padding-right: 1rem;
  }

  .part-center {
    display: flex;
    flex-direction: column;
    align-items: stretch;

    flex: 1 1 60%;
    max-width: 60%;
    padding: 0 1rem;
  }

  .part-right {
    flex: 0 0 20%;
    padding-left: 1rem;
  }

  @media (max-width: 768px) {
    .page-content {
      flex-direction: column;
    }

    .sidebar-left,
    .sidebar-right {
      display: none;
    }

    .main-content {
      flex: 1 1 100%;
      max-width: 100%;
      padding: 0;
    }
  }

  .article-content-card {
    padding: 32px;
  }
</style>
