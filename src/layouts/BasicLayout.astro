---
import { site, layout } from '../config';
import HeadBase from '../components/HeadBase.astro';
import { Image } from 'astro:assets';
import NavBar from '../components/NavBar.astro';
import LoadingIndicator from '../components/LoadingIndicator.astro';

export interface Props {
  coverImage?: ImageMetadata;
  head?: Parameters<typeof HeadBase>[0];
}

const { coverImage: pageCover, head } = Astro.props;

const coverImage = (() => {
  if (pageCover === undefined || pageCover === null) {
    return site.defaultCover;
  } else {
    return pageCover;
  }
})();

const PAGE_ATTR = 'data-basic-layout-page';
---

<html lang={site.lang}>
  <head>
    <HeadBase {...head} />
  </head>
  <body>
    <LoadingIndicator />
    <NavBar transition:name="navbar" />
    <div class="page" {...{ [PAGE_ATTR]: '' }}>
      {
        coverImage && (
          <div
            transition:name="cover-image"
            class:list={['cover-image', site.coverImageStyle]}
          >
            <Image src={coverImage} alt="Cover" />
          </div>
        )
      }
      <div
        class:list={['page-content', 'aside-' + layout.basic.aside]}
        transition:name="page-content"
      >
        <aside class="aside">
          <slot name="aside" />
        </aside>

        <div class="major">
          <slot name="major" />
        </div>
      </div>
    </div>
  </body>
</html>

<script define:vars={{ PAGE_ATTR }}>
  let preservedScroll = 0.0;
  let isOverScroll = false;
  document.addEventListener('astro:before-swap', () => {
    const el = document.querySelector(`[${PAGE_ATTR}]`);
    if (!el) {
      return;
    }
    preservedScroll = el.scrollTop;
    const elCover = el.querySelector('.cover-image');
    if (!elCover) {
      return;
    }
    isOverScroll = preservedScroll > elCover.clientHeight;
  });
  document.addEventListener('astro:after-swap', () => {
    const el = document.querySelector(`[${PAGE_ATTR}]`);
    if (!el) {
      return;
    }
    const elCover = el.querySelector('.cover-image');
    if (!elCover) {
      el.scrollTo(0, 0);
      return;
    }
    if (isOverScroll) {
      el.scrollTo(0, elCover.clientHeight * 0.75);
    } else {
      el.scrollTo(0, preservedScroll);
    }
  });
</script>

<style lang="stylus">
  body {
    background-color: var(--background);
    font-family: var(--font-sans);
    margin: 0;
    min-height: 100vh;
  }

  .page {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;

    parallax() {
      transform-style: preserve-3d;
      perspective: 1px;
    }

    &:has(.parallax) {
      parallax();
    }
    &:has(.half-parallax) {
      parallax();
    }
  }

  .cover-image {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 0 0 auto;

    &.static {
      height: 100vh;
    }

    parallax() {
      transform: translateZ(-1px) scale(2.05);
    }

    &.parallax {
      height: 100vh;
      parallax();
    }

    &.half-parallax {
      height: 50vh;
      transform-origin: 50% 100%;
      parallax();
    }

    img {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .page-content {
    display: flex;
    flex-direction: row;
    width: 100%;
    padding: 72px 128px;
    box-sizing: border-box;
    background-color: var(--background);
    border-radius: 0.75rem;
    box-shadow: 0 -4px 6px -1px var(--shadow);
    margin-top: -@border-radius;
    z-index: 10;

    &.aside-right {
      flex-direction: row-reverse;
    }
  }

  .aside {
    flex: 1 1 10%;
  }

  .major {
    display: flex;
    flex-direction: column;
    align-items: stretch;

    flex: 3 1 50%;
    width: 0;
    padding: 0 1rem;
  }

  @media (max-width: 768px) {
    .page-content {
      padding-left: 0;
      padding-right: 0;
    }

    .major {
      padding: 0;
    }

    .aside {
      display: none;
    }
  }
</style>

<style is:global>
  ::view-transition-group(root) {
    z-index: -1000;
  }

  ::view-transition-group(page-content) {
    z-index: -50;
  }

  ::view-transition-group(cover-image) {
    z-index: -100;
  }
</style>
