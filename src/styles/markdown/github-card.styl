// GitHub 仓库卡片样式（由 ::github[owner/repo] 语法生成）
//
// 三种状态：
//   1. .gh-card--placeholder — 脚本未运行 / 加载失败时的占位链接
//   2. .gh-card--loading      — 数据加载中，显示旋转动画
//   3. .gh-card--loaded       — 完整卡片（所有数据已填充）
//
// 浅色半透明风格，使用 color-mix 让表面色半透明，配合磨砂玻璃效果。

.markdown
  // 覆盖 Markdown 外层 <p> 的居中规则（因为卡片包含 <img> 触发了 p:has(img)）
  p:has(> .gh-card, > .gh-card--loaded)
    text-align: initial

  // 卡片通用半透明背景
  --gh-card-bg: unquote("color-mix(in oklch, var(--surface), transparent 40%)")

  .gh-card--placeholder,
  .gh-card--loading,
  .gh-card--loaded
    background: var(--gh-card-bg)
    backdrop-filter: blur(8px)
    -webkit-backdrop-filter: blur(8px)
    box-shadow: 0 2px 8px var(--shadow)

  // ═══ 占位状态（无 JS / 加载失败回退） ═════════════════════════════
  .gh-card--placeholder
    display: flex
    align-items: center
    gap: 0.5rem
    border: 1px solid var(--border)
    border-radius: 12px
    padding: 0.75rem 1.25rem
    margin: 1rem 0
    text-decoration: none
    color: var(--text-muted)
    font-family: var(--font-sans)
    font-size: 0.9rem
    transition: border-color var(--expressive-default-effects), box-shadow var(--expressive-default-effects)

    &:hover
      border-color: var(--primary)
      color: var(--text)

    .gh-card__name
      font-weight: 600
      color: var(--primary)
      font-family: var(--font-monospace)
      flex: 1
      white-space: nowrap
      overflow: hidden
      text-overflow: ellipsis

    .gh-card__meta
      font-size: 0.8rem
      color: var(--text-muted)
      flex-shrink: 0

  // ═══ 加载状态 ═══════════════════════════════════════════════════════
  .gh-card--loading
    display: flex
    justify-content: space-between
    align-items: center
    border: 1px solid var(--border)
    border-radius: 12px
    padding: 0.75rem 1.25rem
    margin: 1rem 0

    .gh-card__name
      font-family: var(--font-monospace)
      font-weight: 600
      color: var(--primary)

    .gh-card__spinner
      flex-shrink: 0

  .gh-card__spinner
    width: 24px
    height: 24px
    border: 3px solid var(--border)
    border-top-color: var(--primary)
    border-radius: 50%
    animation: gh-card-spin 0.8s linear infinite

  @keyframes gh-card-spin
    to
      transform: rotate(360deg)

  // ═══ 完整卡片状态 ═══════════════════════════════════════════════════
  .gh-card--loaded
    display: block
    border: 1px solid var(--border)
    border-radius: 12px
    padding: 1rem 1.25rem
    margin: 1rem 0
    text-decoration: none
    color: var(--text)
    font-family: var(--font-sans)
    transition: border-color var(--expressive-default-effects), box-shadow var(--expressive-default-effects)

    &:hover
      border-color: var(--primary)
      box-shadow: 0 2px 12px var(--shadow)

    &:active
      transform: scale(0.995)

  .gh-card__header
    display: flex
    justify-content: space-between
    align-items: center
    gap: 0.5rem
    margin-bottom: 0.5rem

  .gh-card__icon
    width: 18px
    height: 18px
    flex-shrink: 0
    color: var(--text-muted)

  .gh-card__name
    font-family: var(--font-monospace)

  .gh-card__header-left
    display: flex
    align-items: center
    gap: 0.5rem
    min-width: 0

  .gh-card__external
    color: var(--text-muted)
    flex-shrink: 0
    transition: color var(--expressive-fast-effects)

  .gh-card--loaded:hover .gh-card__external
    color: var(--primary)

  .gh-card__header .gh-card__avatar
    width: 20px !important
    height: 20px !important
    max-width: none
    min-width: 20px
    min-height: 20px
    margin: 0
    border-radius: 50%
    flex-shrink: 0
    display: block

  .gh-card__desc
    margin: 0 0 0.75rem
    font-size: 0.85rem
    color: var(--text-muted)
    line-height: 1.5
    text-align: left
    display: -webkit-box
    -webkit-line-clamp: 2
    -webkit-box-orient: vertical
    overflow: hidden

  .gh-card__meta
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 1rem
    font-size: 0.8rem
    color: var(--text-muted)

  .gh-card__lang
    display: inline-flex
    align-items: center
    gap: 0.35rem
    font-family: var(--font-monospace)

  .gh-card__lang-dot
    width: 10px
    height: 10px
    border-radius: 50%
    flex-shrink: 0

  .gh-card__stars,
  .gh-card__forks
    display: inline-flex
    align-items: center
    gap: 0.25rem

  .gh-card__updated
    margin-left: auto