
.markdown
  color: var(--text)

  // 标题样式优化
  h1, h2, h3, h4, h5, h6
    font-weight: 600
    line-height: 1.3
    margin-top: 2rem
    margin-bottom: 1rem
    color: var(--text)
    scroll-margin-top: 80px

  // 标题锚点链接
  .heading-anchor
    color: inherit
    text-decoration: none
    display: inline flex
    align-items: center
    gap: 0.5em

    &::after
      display: none

    &::before
      content: '#'
      color: var(--text-muted)
      opacity: 0.3
      font-weight: 400
      font-family: var(--font-monospace)
      transition: opacity var(--expressive-fast-effects)
      font-size: 0.85em

    &:hover::before
      opacity: 0.8

  h1
    font-size: 2rem
    border-bottom: 2px solid var(--border)
    padding-bottom: 0.5rem

  h2
    font-size: 1.5rem
    margin-top: 2.5rem

  h3
    font-size: 1.25rem
    margin-top: 2rem

  h4
    font-size: 1.1rem
    margin-top: 1.75rem

  h5
    font-size: 1rem
    margin-top: 1.5rem

  h6
    font-size: 0.9rem
    margin-top: 1.5rem
    color: var(--text-muted)

  // 段落样式
  p
    line-height: 1.75
    margin-bottom: 1.25rem
    letter-spacing: 0.01em

  // 链接样式
  a
    text-decoration: none
    color: var(--secondary)
    transition: color var(--expressive-fast-effects)

    &:hover
      color: var(--primary)

  // 内联代码
  code
    font-family: var(--font-monospace)
    color: var(--on-secondary-container)
    background-color: var(--secondary-container)
    padding: 0.2em 0.4em
    margin: 0 0.2em
    border-radius: 6px
    font-size: 0.9em
    border: 1px solid var(--border)
    line-break: anywhere

  // 图片样式
  p:has(img)
    text-align: center

  img
    border-radius: 8px
    max-width: 100%
    height: auto
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)
    margin: 1rem 0

  // 列表样式
  ul, ol
    padding-left: 1.5rem
    margin-bottom: 1.25rem
    
    li
      margin-bottom: 0.5rem
      line-height: 1.6

    ul, ol
      margin-top: 0.5rem
      margin-bottom: 0.5rem

  // 引用块样式
  blockquote
    border-left: 4px solid var(--primary)
    padding: 1rem 1.5rem
    margin: 1.5rem 0
    background-color: var(--surface-container)
    border-radius: 0 8px 8px 0
    color: var(--text-muted)
    font-style: italic

    p:last-child
      margin-bottom: 0

  // 表格样式
  table
    width: 100%
    border-collapse: separate
    border-spacing: 0
    margin: 2rem 0
    overflow: hidden
    border-radius: 8px
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08)
    background-color: var(--surface)
    border: 1px solid var(--border)

    thead
      background-color: var(--primary-container)
      color: var(--on-primary-container)

    th
      padding: 1rem 1.25rem
      font-weight: 600
      border-bottom: 2px solid var(--border)
      white-space: nowrap

    td
      padding: 0.875rem 1.25rem
      border-bottom: 1px solid var(--border)

    tbody tr:last-child td
      border-bottom: none

    // 响应式处理
    @media (max-width: 768px)
      display: block
      overflow-x: auto
      -webkit-overflow-scrolling: touch

      th, td
        padding: 0.75rem 1rem
        min-width: 120px

  // 水平线
  hr
    border: none
    height: 1px
    background: var(--border)
    margin: 2rem 0

  // 粗体和斜体
  strong
    font-weight: 600
    color: var(--text)

  em
    font-style: italic

  // 删除线
  del
    color: var(--text-muted)
    text-decoration: line-through

  // 任务列表
  input[type="checkbox"]
    margin-right: 0.5rem
    accent-color: var(--primary)

  // 代码块容器样式（Expressive Code）
  pre
    border-radius: 12px
    overflow: hidden
    margin: 1.5rem 0
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)

    code
      background-color: transparent
      border: none
      padding: 0
      margin: 0
      font-size: inherit
