---
import MarkdownWrapper from './MarkdownWrapper.astro';
import Heimu from './Heimu.astro';
import CopyrightNotice from './CopyrightNotice.astro';
import CategoryBreadcrumb from './MetaWidgets/CategoryBreadcrumb.astro';

import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { processPost } from '../server/utils';
import TimeMeta from './MetaWidgets/TimeMeta.astro';
import TagsMeta from './MetaWidgets/TagsMeta.astro';
import StatsMeta from './MetaWidgets/StatsMeta.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const { category, description, title, tags } = post.data;

const { updateDate, pubDate } = processPost(post);

const { Content, headings } = await render(post);

const customComponents = {
  Heimu,
};
---

<div class="post-content">
  <div class="article-header">
    <CategoryBreadcrumb category={category} />
    <h1 data-transite-from-title class="article-title">{title}</h1>
    <TagsMeta tags={tags} />
    <div class="meta-row">
      <TimeMeta icon="mdi:calendar-outline" time={pubDate} label="发布于" />
      <TimeMeta
        icon="mdi:calendar-edit-outline"
        time={updateDate}
        label="更新于"
      />
    </div>
    <StatsMeta content={post.body ?? ''} />
    {description?.trim() && <div class="description">{description}</div>}
  </div>
  <hr />
  <MarkdownWrapper>
    <Content components={customComponents} />
  </MarkdownWrapper>
  <hr />
  <CopyrightNotice post={post} />
</div>

<style lang="stylus">
  .post-content {
    .article-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      padding: 24px 0;
    }

    .article-title {
      margin: 0;
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
      text-align: center;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
    }

    hr {
      margin: 24px -8px;
      border-style: dashed;
      opacity: 0.5;
    }

    .description {
      color: var(--text-muted);
      line-height: 1.6;
      text-align: center;
      max-width: 80%;
    }
  }
</style>
